{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "plan": {
      "mode": "primary",
      "model": "ollama/gemma4-agent",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      },
      "parameters": {
        "num_ctx": 32768
      },
      "capability": ["plan"]
    },
    "build": {
      "mode": "primary",
      "model": "ollama/qwen-9b-32k",
      "permission": {
        "edit": "allow",
        "bash": {
          "read": "allow",
          "write": "ask"
        }
      },
      "parameters": {
        "num_ctx": 32768
      },
      "capability": ["build", "exec"]
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen-9b-32k": {
          "tools": true
        },
        "gemma4-agent": {
          "tools": true
        }
      }
    }
  },
  "instructions": [
    "~/.config/opencode/AGENTS.md"
  ],
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "@zilliz/memsearch-opencode"
  ]
}
