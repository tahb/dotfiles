  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/block-dangerous-git.sh\""
          }
        ]
      },
      {
        "matcher": "Bash(git cherry-pick *)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"PIPELINE GATE: Before cherry-picking, you must have shown the user the commit message, diff summary, and test results, and received explicit approval. If you have not done this, abort and present the proposal now.\"}}'"
          }
        ]
      },
      {
        "matcher": "Bash(git -C * cherry-pick *)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"PIPELINE GATE: Before cherry-picking, you must have shown the user the commit message, diff summary, and test results, and received explicit approval. If you have not done this, abort and present the proposal now.\"}}'"
          }
        ]
      },
      {
        "matcher": "Bash(git commit *)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"PIPELINE GATE: Before committing, you must have shown the user the proposed commit message + diff summary and received explicit approval. If you have not done this, abort and present the proposal now.\"}}'"
          }
        ]
      },
      {
        "matcher": "Bash(git -C * commit *)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"PIPELINE GATE: Before committing, you must have shown the user the proposed commit message + diff summary and received explicit approval. If you have not done this, abort and present the proposal now.\"}}'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"SessionStart\",\"additionalContext\":\"CAVEMAN ULTRA MODE ACTIVE from session start. Apply all caveman rules immediately and for the entire session. Drop articles, filler, pleasantries, hedging. Fragments OK. Short synonyms. One word when one word enough. Pattern: [thing] [action] [reason]. Never revert unless user says stop caveman or normal mode. No jokes, no humour, no wit.\\n\\nPIPELINE MANDATE: Code-change requests follow 12-step pipeline (scout → plan → plan-gate → builder/worktree → e2e red → TDD + commit → quick review → deep review → e2e pass → scribe → cherry-pick → cleanup). First action on any code change: invoke scout subagent. No carve-out for trivial. See ~/.config/opencode/AGENTS.md for full spec.\"}}'",
            "statusMessage": "Activating caveman + pipeline mode..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"UserPromptSubmit\",\"additionalContext\":\"PIPELINE REMINDER: For any code change, start with scout subagent. Pipeline mandatory: scout → plan → gate → builder → reviews → e2e → scribe → cherry-pick → cleanup. No trivial carve-out.\"}}'"
          }
        ]
      }
    ]
  },
  "disableAgentView": true,
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); model=$(echo \"$input\" | jq -r '.model.display_name // empty'); ctx=$(echo \" $input \" | jq -r '.context_window.used_percentage // empty'); tokens=$(echo \" $input \" | jq -r '.context_window.total_input_tokens // empty'); pr=$(echo \" $input \" | jq -r '.pr.review_state // empty'); effort=$(echo \" $input \" | jq -r '.effort.level // empty'); parts=(); [ -n \"$model\" ] && parts+=(\"$model\"); [ -n \"$effort\" ] && parts+=(\"effort:$effort\"); [ -n \"$ctx\" ] && parts+=(\"ctx:$(printf '%.0f' \"$ctx\")%\"); [ -n \"$tokens\" ] && parts+=(\"${tokens}tk\"); [ -n \"$pr\" ] && parts+=(\"pr:$pr\"); IFS='|'; echo \"${parts[*]}\""
  },
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true,
    "caveman@caveman": false,
    "memsearch@memsearch-plugins": false,
    "frontend-design@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "memsearch-plugins": {
      "source": {
        "source": "github",
        "repo": "zilliztech/memsearch"
      }
    }
  },
  "effortLevel": "xhigh",
  "theme": "light-daltonized",
  "remoteControlAtStartup": false,
  "inputNeededNotifEnabled": true,
  "maxTurns": 50
}
