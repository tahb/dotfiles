{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "dev",
  "permission": {
    "read": {
      ".env": "deny",
      "**/.env": "deny",
      "*": "allow"
    },
    "bash": {
      "git commit*": "ask",
      "git push*": "deny",
      "git reset --hard*": "deny",
      "git clean -f*": "deny",
      "git branch -D*": "deny",
      "git branch*": "ask",
      "git checkout .*": "deny",
      "git checkout --*": "deny",
      "git checkout*": "ask",
      "git restore .*": "deny",
      "*": "allow"
    }
  },
  "shell": "~/.config/opencode/hooks/block-dangerous-git.sh",
  "agent": {
    "plan": {
     "disable": true
    },
    "build": {
     "disable": true
    },
    "scout": {
      "mode": "subagent",
      "color": "#5BA3A0",
      "model": "openai/gpt-5.4-mini",
      "description": "Read-only codebase research agent.",
      "permission": {
        "read": {
          ".env": "deny",
          "**/.env": "deny",
          "*": "allow"
        },
        "edit": "deny",
        "bash": {
          "git commit*": "ask",
          "git push*": "deny",
          "git reset --hard*": "deny",
          "git clean -f*": "deny",
          "git branch -D*": "deny",
          "git branch*": "ask",
          "git checkout .*": "deny",
          "git checkout --*": "deny",
          "git checkout*": "ask",
          "git restore .*": "deny",
          "*": "allow"
        }
      },
      "prompt": "{file:./prompts/scout.md}"
    },
    "dev": {
      "mode": "primary",
      "color": "#D4396B",
      "model": "openai/gpt-5.4",
      "description": "Main orchestrator agent.",
      "permission": {
        "read": {
          ".env": "deny",
          "**/.env": "deny",
          "*": "allow"
        },
        "edit": "deny",
        "bash": {
          "git commit*": "ask",
          "git push*": "deny",
          "git reset --hard*": "deny",
          "git clean -f*": "deny",
          "git branch -D*": "deny",
          "git branch*": "ask",
          "git checkout .*": "deny",
          "git checkout --*": "deny",
          "git checkout*": "ask",
          "git restore .*": "deny",
          "*": "allow"
        }
      },
      "prompt": "{file:./prompts/dev.md}"
    },
    "local": {
      "mode": "primary",
      "color": "#3B6D11",
      "model": "ollama/gemma4-12b-32k",
      "permission": {
        "read": {
          ".env": "deny",
          "**/.env": "deny",
          "*": "allow"
        },
        "edit": "ask",
        "bash": {
          "git commit*": "ask",
          "git push*": "deny",
          "git reset --hard*": "deny",
          "git clean -f*": "deny",
          "git branch -D*": "deny",
          "git branch*": "ask",
          "git checkout .*": "deny",
          "git checkout --*": "deny",
          "git checkout*": "ask",
          "git restore .*": "deny",
          "*": "allow"
        }
      },
      "options": {
        "num_ctx": 32768
      }
    },
    "planner": {
      "mode": "subagent",
      "color": "#0F6E56",
      "model": "openai/gpt-5.5",
      "description": "Planning agent that breaks software engineering goals into ordered task lists.",
      "permission": {
        "read": {
          ".env": "deny",
          "**/.env": "deny",
          "*": "allow"
        },
        "edit": "deny",
        "bash": {
          "git commit*": "ask",
          "git push*": "deny",
          "git reset --hard*": "deny",
          "git clean -f*": "deny",
          "git branch -D*": "deny",
          "git branch*": "ask",
          "git checkout .*": "deny",
          "git checkout --*": "deny",
          "git checkout*": "ask",
          "git restore .*": "deny",
          "*": "allow"
        }
      },
      "prompt": "{file:./prompts/plan.md}"
    },
    "builder": {
      "mode": "primary",
      "color": "#BA7517",
      "model": "openai/gpt-5.4",
      "description": "Implementation agent for code and tests.",
      "permission": {
        "read": {
          ".env": "deny",
          "**/.env": "deny",
          "*": "allow"
        },
        "edit": "ask",
        "bash": {
          "git commit*": "ask",
          "git push*": "deny",
          "git reset --hard*": "deny",
          "git clean -f*": "deny",
          "git branch -D*": "deny",
          "git branch*": "ask",
          "git checkout .*": "deny",
          "git checkout --*": "deny",
          "git checkout*": "ask",
          "git restore .*": "deny",
          "*": "allow"
        }
      },
      "prompt": "{file:./prompts/build.md}"
    },
    "reviewer": {
      "mode": "subagent",
      "color": "#993556",
      "model": "openai/gpt-5.5",
      "description": "Specialized agent for code quality and logic verification.",
      "permission": {
        "read": {
          ".env": "deny",
          "**/.env": "deny",
          "*": "allow"
        },
        "edit": "deny",
        "bash": {
          "git commit*": "ask",
          "git push*": "deny",
          "git reset --hard*": "deny",
          "git clean -f*": "deny",
          "git branch -D*": "deny",
          "git branch*": "ask",
          "git checkout .*": "deny",
          "git checkout --*": "deny",
          "git checkout*": "ask",
          "git restore .*": "deny",
          "*": "allow"
        }
      },
      "prompt": "{file:./prompts/review.md}"
    },
    "tester": {
      "mode": "subagent",
      "color": "#2E7D32",
      "model": "openai/gpt-5.4-mini",
      "description": "Tester subagent. Runs full suite in worktree, reports pass/fail counts and percentage.",
      "permission": {
        "read": {
          ".env": "deny",
          "**/.env": "deny",
          "*": "allow"
        },
        "edit": "deny",
        "bash": {
          "git commit*": "ask",
          "git push*": "deny",
          "git reset --hard*": "deny",
          "git clean -f*": "deny",
          "git branch -D*": "deny",
          "git branch*": "ask",
          "git checkout .*": "deny",
          "git checkout --*": "deny",
          "git checkout*": "ask",
          "git restore .*": "deny",
          "*": "allow"
        }
      },
      "prompt": "{file:./prompts/tester.md}"
    },
    "scribe": {
      "mode": "subagent",
      "color": "#5BA3A0",
      "model": "openai/gpt-5.4-mini",
      "description": "Specialist for technical documentation sync.",
      "permission": {
        "read": {
          ".env": "deny",
          "**/.env": "deny",
          "*": "allow"
        },
        "edit": "ask",
        "bash": {
          "git commit*": "ask",
          "git push*": "deny",
          "git reset --hard*": "deny",
          "git clean -f*": "deny",
          "git branch -D*": "deny",
          "git branch*": "ask",
          "git checkout .*": "deny",
          "git checkout --*": "deny",
          "git checkout*": "ask",
          "git restore .*": "deny",
          "*": "allow"
        }
      },
      "prompt": "{file:./prompts/scribe.md}"
    }
  },
  "skills": {
    "paths": [
      "~/.config/opencode/skills"
    ]
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen-9b-32k": {
          "tools": true
        },
        "gemma4-agent": {
          "tools": true
        },
        "gemma4-12b-32k": {
          "tools": true
        }
      }
    },
    "google": {
      "options": {
        "authType": "oauth-personal"
      }
    }
  },
  "instructions": [
    "~/.config/opencode/AGENTS.md"
  ],
  "plugin": [
  ]
}
